{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "1800000",
    "BASH_MAX_TIMEOUT_MS": "1800000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "if": "Bash(trackgentic *)",
            "command": "bun .claude/hooks/enforce-trackgentic-token.ts",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "bun .claude/hooks/enforce-issue-cleanup.ts",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bun .claude/hooks/inject-agent-markers.ts",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(bun .claude/hooks/*)",
      "Bash(bun .claude/skills/**)",
      "Write(.claude/**)",
      "Edit(.claude/**)",
      "MultiEdit(.claude/**)",
      "Bash(trackgentic *)",
      "Bash(TRACKGENTIC_USER_TOKEN=* trackgentic *)",
      "Bash(cd packages/library && bun run *)",
      "Bash(cd packages/library && bun test *)"
    ]
  }
}