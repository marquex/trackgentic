{
  "name": "trackgentic",
  "version": "0.1.0",
  "description": "Issue tracker designed for AI agents — file-backed, event-sourced, git-friendly",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "trackgentic": "./dist/bin.js"
  },
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "docs:generate": "typedoc",
    "docs:check": "typedoc --emit none",
    "quality": "bun run typecheck && bun run lint && bun run test:coverage",
    "build": "tsup",
    "prepublishOnly": "bun run quality"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/bun": "^1.2.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.33.0"
  }
}
